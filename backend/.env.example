# Redis (Upstash hoặc redis://redis:6379 nếu chạy Redis container)
REDIS_URL=

# PostgreSQL (container name: postgres)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/auth_demo
POSTGRES_DB=auth_demo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# JWT signing key (đổi thành chuỗi ngẫu nhiên ≥ 32 ký tự trên production)
JWT_SECRET=change-me-to-a-long-random-secret-key
